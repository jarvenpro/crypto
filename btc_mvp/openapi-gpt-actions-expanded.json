      "get": {
        "operationId": "getCftcBitcoinCot",
        "summary": "Get CFTC bitcoin commitment of traders data",
        "description": "Returns recent CFTC bitcoin positioning data, helpful for futures market structure and sentiment analysis.",
        "parameters": [
          {
            "name": "exchange",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "cme"
            },
            "description": "Exchange filter. Use cme or all."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 4,
