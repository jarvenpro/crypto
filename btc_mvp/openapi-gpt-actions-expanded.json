{
  "openapi": "3.1.0",
  "info": {
    "title": "Crypto GPT Aggregator API",
    "version": "1.1.0",
    "description": "Expanded Custom GPT action schema for real-time crypto, macro, regulatory, and market structure data. Use overview endpoints for synthesis and source endpoints for targeted checks. Authenticate with Bearer token in GPT action settings."
  },
  "servers": [
    {
      "url": "https://crypto-o8fu.onrender.com",
      "description": "Public HTTPS base URL for the deployed aggregator API."
    }
  ],
  "paths": {
    "/v1/crypto/overview": {
      "get": {
        "operationId": "getCryptoOverview",
        "summary": "Get a real-time crypto market overview",
        "description": "Best default endpoint for crypto direction judgment. Returns a compact snapshot including Binance market data, Fear and Greed index, mempool fees for BTC, and CoinGecko price context.",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "BTCUSDT"
            },
            "description": "Trading symbol, usually BTCUSDT."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/v1/macro/overview": {
      "get": {
        "operationId": "getMacroOverview",
        "summary": "Get a macro overview",
        "description": "Best default endpoint for macro context. Returns Federal Reserve monetary updates, Treasury rates, CPI from BLS, selected FRED series when configured, and BEA GDP when configured.",
        "parameters": [
          {
            "name": "fred_series",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "FEDFUNDS,DGS10,UNRATE"
            },
            "description": "Comma-separated FRED series IDs."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/v1/regulatory/overview": {
      "get": {
        "operationId": "getRegulatoryOverview",
        "summary": "Get a regulatory and ETF filing overview",
        "description": "Best default endpoint for regulatory context. Returns recent SEC filings for major bitcoin ETF entities and CFTC bitcoin positioning data.",
        "parameters": [
          {
            "name": "entities",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "IBIT,FBTC,GBTC"
            },
            "description": "Comma-separated SEC tickers or CIKs."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/v1/sources/binance/market": {
      "get": {
        "operationId": "getBinanceMarket",
        "summary": "Get Binance spot and futures snapshot",
        "description": "Returns spot price, book ticker, open interest, funding rate, taker ratio, long-short ratio, and recent candles from Binance.",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "BTCUSDT"
            },
            "description": "Trading symbol, usually BTCUSDT."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/v1/sources/coingecko/simple-price": {
      "get": {
        "operationId": "getCoinGeckoSimplePrice",
        "summary": "Get CoinGecko simple price data",
        "description": "Returns spot price context, market cap, volume, and 24h change from CoinGecko for a chosen asset ID.",
        "parameters": [
          {
            "name": "asset_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "bitcoin"
            },
            "description": "CoinGecko asset ID, such as bitcoin."
          },
          {
            "name": "vs_currency",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "usd"
            },
            "description": "Quote currency such as usd."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/v1/sources/coinglass/market-structure": {
      "get": {
        "operationId": "getCoinGlassMarketStructure",
        "summary": "Get CoinGlass derivatives structure snapshot",
        "description": "Returns CoinGlass derivatives structure data focused on a chosen exchange and symbol, including open interest, funding, OI-weighted funding, long-short ratio, liquidation structure, and exchange rank context.",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "BTCUSDT"
            },
            "description": "Trading symbol such as BTCUSDT. The server normalizes this to the coin symbol used by CoinGlass."
          },
          {
            "name": "exchange",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "OKX"
            },
            "description": "Exchange to focus on, such as OKX or Binance."
          },
          {
            "name": "interval",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "1h"
            },
            "description": "Candle interval such as 1h or 4h."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/v1/sources/fear-greed/latest": {
      "get": {
        "operationId": "getFearGreedLatest",
