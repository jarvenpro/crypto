    "/v1/sources/fed/monetary-feed": {
      "get": {
        "operationId": "getFedMonetaryFeed",
        "summary": "Get Federal Reserve monetary updates",
        "description": "Returns recent Federal Reserve monetary-policy RSS items such as FOMC statements and minutes.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 5,
              "minimum": 1,
              "maximum": 10
            },
            "description": "Number of feed items to return."
          }
