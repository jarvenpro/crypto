    "/v1/sources/sec/submissions/{entity}": {
      "get": {
        "operationId": "getSecSubmissions",
        "summary": "Get SEC submissions by ticker or CIK",
        "description": "Returns recent SEC filings for a ticker or CIK, useful for ETF issuers and related entities.",
        "parameters": [
          {
            "name": "entity",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "SEC ticker or CIK, such as IBIT."
          },
          {
            "name": "forms_limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 20
            },
            "description": "Maximum number of recent filings to return."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
