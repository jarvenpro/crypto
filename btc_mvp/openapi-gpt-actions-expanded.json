    "/v1/sources/bls/series/{series_id}": {
      "get": {
        "operationId": "getBlsSeries",
        "summary": "Get BLS time series observations",
        "description": "Returns recent observations for a BLS series such as CUUR0000SA0 for CPI.",
        "parameters": [
          {
            "name": "series_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "BLS series ID, such as CUUR0000SA0."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 12,
              "minimum": 1,
              "maximum": 24
            },
            "description": "Maximum number of observations to return."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/v1/sources/fred/series/{series_id}": {
      "get": {
        "operationId": "getFredSeries",
        "summary": "Get FRED time series observations",
        "description": "Returns recent observations for a FRED series such as FEDFUNDS, DGS10, or UNRATE. Requires FRED API key to be configured on the server.",
        "parameters": [
          {
            "name": "series_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "FRED series ID, such as FEDFUNDS."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 12,
              "minimum": 1,
              "maximum": 24
            },
            "description": "Maximum number of observations to return."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
