        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "GatewayApiKey": {
        "type": "apiKey",
        "description": "Set this to your GATEWAY_API_TOKEN value.",
        "in": "header",
        "name": "X-API-Key"
      },
      "GatewayBearer": {
        "type": "http",
        "description": "Optional alternative to X-API-Key. Use Bearer <GATEWAY_API_TOKEN>.",
        "scheme": "bearer"
      }
    }
  },
  "servers": [
